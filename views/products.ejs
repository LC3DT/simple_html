<h2 style="margin-bottom:20px;">全部商品</h2>

<form class="search-bar" method="GET" action="/products">
  <input type="text" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="搜索商品...">
  <button type="submit" class="btn">搜索</button>
</form>

<% if (typeof q !== 'undefined' && q) { %>
  <p style="margin-bottom:16px;color:#666;">搜索 "<%= q %>" 的结果：</p>
<% } %>

<div class="product-grid">
  <% products.forEach(p => { %>
    <div class="product-item">
      <div class="category"><%= p.category %></div>
      <h3><a href="/products/<%= p.id %>"><%= p.name %></a></h3>
      <div class="desc"><%= p.description %></div>
      <div class="price">¥<%= p.price.toFixed(2) %></div>
    </div>
  <% }); %>
</div>

<% if (products.length === 0) { %>
  <p style="text-align:center;color:#999;padding:40px;">没有找到相关商品</p>
<% } %>
